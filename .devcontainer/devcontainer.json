{
  "name": "OldSkoolTerminalGame",
  "image": "mcr.microsoft.com/devcontainers/cpp:1-debian-12",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "src/TerminalCartridge.cpp",
        "include/TerminalCartridge.h"
      ]
    },
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools"
      ],
      "settings": {
        "workbench.startupEditor": "none",
        "files.associations": {
          "*.h": "cpp"
        }
      }
    }
  }
}