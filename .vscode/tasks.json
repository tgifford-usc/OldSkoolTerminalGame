{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "▶ Run Terminal Game",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "rm -f game && g++ -std=c++17 -Wall -Wextra src/*.cpp src/*/*.cpp -Iinclude -o game && ./game"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "problemMatcher": "$gcc"
    }
  ]
}